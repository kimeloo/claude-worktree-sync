{
  "name": "claude-worktree-sync",
  "displayName": "Claude Worktree Sync",
  "description": "Automatically detect and sync Claude Code worktrees to your VSCode workspace",
  "version": "0.1.0",
  "publisher": "kimeloo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimeloo/claude-worktree-sync.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.claude",
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Worktree Sync",
      "properties": {
        "claudeWorktreeSync.autoAdd": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add detected worktrees to workspace"
        },
        "claudeWorktreeSync.autoRemove": {
          "type": "boolean",
          "default": true,
          "description": "Automatically remove deleted worktrees from workspace"
        },
        "claudeWorktreeSync.pollingInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Polling interval in milliseconds (fallback for fs.watch)"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "claudeWorktrees",
          "name": "Claude Worktrees"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeWorktreeSync.refreshWorktrees",
        "title": "Refresh Worktrees",
        "category": "Claude Worktree Sync",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeWorktreeSync.addWorktreeToWorkspace",
        "title": "Add Worktree to Workspace",
        "category": "Claude Worktree Sync",
        "icon": "$(add)"
      },
      {
        "command": "claudeWorktreeSync.removeWorktreeFromWorkspace",
        "title": "Remove Worktree from Workspace",
        "category": "Claude Worktree Sync",
        "icon": "$(trash)"
      },
      {
        "command": "claudeWorktreeSync.openTerminal",
        "title": "Open Terminal",
        "category": "Claude Worktree Sync",
        "icon": "$(terminal)"
      },
      {
        "command": "claudeWorktreeSync.viewDiff",
        "title": "View Diff",
        "category": "Claude Worktree Sync",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeWorktreeSync.addWorktreeToWorkspace",
          "when": "view == claudeWorktrees",
          "group": "navigation"
        },
        {
          "command": "claudeWorktreeSync.refreshWorktrees",
          "when": "view == claudeWorktrees",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeWorktreeSync.addWorktreeToWorkspace",
          "when": "view == claudeWorktrees && viewItem == worktreeNotInWorkspace",
          "group": "1_sync"
        },
        {
          "command": "claudeWorktreeSync.removeWorktreeFromWorkspace",
          "when": "view == claudeWorktrees && viewItem == worktreeInWorkspace",
          "group": "1_sync"
        },
        {
          "command": "claudeWorktreeSync.openTerminal",
          "when": "view == claudeWorktrees",
          "group": "2_actions"
        },
        {
          "command": "claudeWorktreeSync.viewDiff",
          "when": "view == claudeWorktrees",
          "group": "2_actions"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
